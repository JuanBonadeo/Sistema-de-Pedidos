# Supabase (values from `supabase status` when running locally, or from
# your cloud project in prod).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Host used to distinguish subdomain (prod) from path (dev).
# Dev: localhost:3000
# Prod: miapp.com
ROOT_DOMAIN=localhost:3000

# Upstash Redis for rate limiting (createOrder). Create a free DB at
# upstash.com and grab the REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth (for customer "Continuar con Google")
# 1. Google Cloud Console → Create OAuth 2.0 Client ID (Web app)
# 2. Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
# 3. Put the values below + restart `pnpm exec supabase start`.

GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
